  }
]
[
  {
    "master_group": "Group 5: Communication Infrastructure & Ecosystem Risks",
    "controls": [
      {
        "as-if_id": "as-if-05-001",
        "meta": {
          "version": "1.0.0",
          "author": "Nick DeMeo (DeMeoLogic)",
          "license": "Apache-2.0"
        },
        "classification": {
          "cisco_objective": "Communication Compromise",
          "cisco_technique": "API Execution Hijacking",
